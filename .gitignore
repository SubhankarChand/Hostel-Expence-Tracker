# ============================================
# HostelSplit - Git Ignore File
# Keep all working files locally, exclude from GitHub
# ============================================

# Dependencies (reinstall on other machines)
**/node_modules/
node_modules/

# Environment variables (contains passwords/secrets)
**/.env
.env
**/.env.local
.env.local

# Database files
*.sqlite
*.db
*.sqlite3

# Build outputs (generated files)
**/dist/
**/build/
dist/
build/

# Logs
**/logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE files (personal preferences)
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# Backup files
*.bak
*.backup
*.old

# Temporary files
tmp/
temp/
*.tmp

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Coverage directory
coverage/
*.lcov

# Optional: Keep package-lock.json (uncomment if you want to ignore it)
# **/package-lock.json

# Start script (optional to exclude)
# start.bat

# PostgreSQL data (if you have local data folder)
postgres-data/